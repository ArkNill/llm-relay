# llm-relay environment configuration
# Copy this file to .env and adjust values for your setup.
#
# Usage modes:
#   1. CLI only (pip install llm-relay)     → no env vars needed
#   2. MCP server (llm-relay-mcp)           → no env vars needed
#   3. Docker proxy + dashboard             → configure below

# ── Proxy settings (Docker mode) ──────────────────────────────────
# Upstream API endpoint
LLM_RELAY_UPSTREAM=https://api.anthropic.com

# Database path (inside container; host path is mapped via docker-compose volumes)
LLM_RELAY_DB=/data/legacy/usage.db

# Proxy listen port
LLM_RELAY_PORT=8080

# ── Feature toggles ──────────────────────────────────────────────
# FeatureFlags intercept (0=off, 1=on)
LEGACY_TOGGLE=0

# Request body normalization for prompt cache stability (0=off, 1=on)
LLM_RELAY_CACHE_FIX=0

# Scan incoming requests with detectors (0=off, 1=on; saves ~100-350ms/req when off)
LLM_RELAY_SCAN_ENABLED=0

# tokpress compression (0=off, 1=on)
LLM_RELAY_TOKPRESS=0

# Parse SSE streams for token usage tracking (0=off, 1=on)
LLM_RELAY_SSE_PARSE_USAGE=1

# ── Turn counter thresholds (Zone A: absolute, Zone B: ratio) ────
# Zone A — absolute token count thresholds
CC_TOKEN_A_YELLOW=300000
CC_TOKEN_A_ORANGE=500000
CC_TOKEN_A_RED=750000
CC_TOKEN_A_HARD=900000

# Context window ceiling (for ratio calculation)
CC_TOKEN_CEILING=1000000
